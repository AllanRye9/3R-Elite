# ============================================================
# Docker Compose environment variables
# Copy this file to .env and fill in the values before running
# docker-compose up -d
# ============================================================

# --- PostgreSQL -------------------------------------------------
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace_secret
POSTGRES_DB=marketplace_db

# --- JWT (REQUIRED – change these to long random strings) -------
JWT_SECRET=change-this-jwt-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS -------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Add every deployment URL that should be permitted, e.g.:
# CORS_ORIGIN=https://client-production-9fdc.up.railway.app,https://3r-elite-frontend.onrender.com
CORS_ORIGIN=http://localhost:3000

# --- Frontend API URL -------------------------------------------
# Browser-accessible URL of the backend API.
# For local Docker: keep as http://localhost:5000 (port 5000 is
# exposed to the host by docker-compose).
# For remote deployment: set to the public backend URL, e.g.
# https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- AWS S3 (optional – only required for image uploads) --------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# --- Rate limiting ----------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
